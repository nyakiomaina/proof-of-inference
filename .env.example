# Proof of Inference — root env vars (copy to `.env` for local scripts; never commit secrets)

# --- Compile-time overrides for `programs/proof-of-inference/build.rs` --------
# These pubkeys are baked into the program by build.rs. Override BEFORE running
# `anchor build` (the build script picks them up via `cargo:rerun-if-env-changed`).

# Test-only off-chain callback signer. Default omitted → matches
# `tests/fixtures/arcium_callback_authority.json` so the integration tests can
# simulate the MPC callback. Production deployments may set this to a multisig
# pubkey to be used as an ops-rescue path; the production traffic still flows
# through MXE_CALLBACK_AUTHORITY.
# POI_ARCIUM_CALLBACK_AUTHORITY=

# Production callback signer: deterministic PDA the MXE program signs with.
# Default matches mxe/poi_mxe/target/deploy/poi_mxe_scaffold-keypair.json.
# Recompute via:
#   solana find-program-derived-address $MXE_PROGRAM_ID string:ArciumSignerAccount
# whenever you redeploy the MXE to a new address.
# POI_MXE_SIGN_PDA=

# --- Deployed proof_of_inference program (also in Anchor.toml) ---------------
# POI_PROGRAM_ID=5s7exNede5PNdwQYH6vguTGNV6K2iT5nQWo1SLrMGWgh

# --- Helper script config ----------------------------------------------------
# scripts/fetch-user-inferences.cjs — wallet pubkey to filter VerifiedInference accounts
# REQUESTER_WALLET=

# Solana JSON-RPC for read-only scripts.
# RPC_URL=http://127.0.0.1:8899

# --- Frontend (also lives in app/.env.example) -------------------------------
# After `arcium deploy`, set the MXE program id for the app.
# VITE_MXE_PROGRAM_ID=

# Arcium cluster offsets (see mxe/poi_mxe/Arcium.toml and Arcium deployment docs).
# ARCIUM_CLUSTER_OFFSET_DEVNET=456
# ARCIUM_CLUSTER_OFFSET_MAINNET=2026
