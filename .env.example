# Proof of Inference + Arcium (copy to `.env` for local scripts; never commit secrets)

# proof_of_inference program (see Anchor.toml)
# POI_PROGRAM_ID=CCdibNmqNCG58v4fVjAKvwXora2ekGYToUTTQF6QVmuh

# Solana JSON-RPC for scripts/watch-inference-requested.cjs
