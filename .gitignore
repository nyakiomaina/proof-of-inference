# Dependencies
node_modules/

# Rust / Anchor / Solana — ignore target/ contents but keep program keypairs
# tracked so `anchor deploy` reproduces the same program IDs across machines.
# These exceptions intentionally expose the upgrade authority — DO NOT use
# these keys for mainnet. Mainnet should regenerate keypairs and use a
# multisig (Squads) as the upgrade authority.
target
!target/
target/*
!target/deploy/
target/deploy/*
!target/deploy/*-keypair.json
**/*.rs.bk
.anchor/

# Local validator ledgers (if started outside .anchor/)
test-ledger/

# TypeScript / tooling output
dist/
*.tsbuildinfo

# Arcis / local circuit build output at repo root (regenerate via arcium / toolchain)
/build/

# Local agent / IDE (do not commit)
.claude/

# Env and secrets (keep local only)
.env
.env.*
!.env.example

# Optional: local-only Arcium callback test keypair (uncomment if you never want it in git)
# tests/fixtures/arcium_callback_authority.json

# OS / editors
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.log
