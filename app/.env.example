# Frontend environment variables for the Proof of Inference app.
# Copy this file to `app/.env` and fill in the values.
#
# NOTE: Vite substitutes these at *build time* into the JS bundle. For the
# Fly deployment this means the values must be present when the Dockerfile
# runs `npm run build` — `fly secrets set` (runtime only) will NOT work.
# See README.md "Environment variables" for details.

# --- Solana cluster -----------------------------------------------------------
# One of: "devnet" | "testnet" | "mainnet-beta"
VITE_SOLANA_CLUSTER=devnet

# Optional explicit RPC endpoint. Overrides the default clusterApiUrl() lookup.
# Recommended for production (public devnet RPC is flaky for anything serious).
# VITE_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# --- Arcium MXE --------------------------------------------------------------
# MXE scaffold program ID (from `arcium deploy`; see mxe/poi_mxe/Anchor.toml).
# Default below is the keypair currently checked in at
# mxe/poi_mxe/target/deploy/poi_mxe_scaffold-keypair.json. Override after a
# fresh `arcium deploy` to a different keypair.
VITE_MXE_PROGRAM_ID=EFZ1VFf9ws338N9YktYuVQXB8ascEhQ3agtRvVE2rzKF

# Arcium cluster offset. Auto-picks by VITE_SOLANA_CLUSTER if unset
# (devnet=456, mainnet-beta=2026). Override if you're running a private cluster.
# VITE_ARCIUM_CLUSTER_OFFSET=456

# --- Protocol fee plumbing (output of `node scripts/devnet-setup.js`) --------
# SPL token account (owned by the deployer wallet) that pays the inference fee.
VITE_REQUESTER_TOKEN_ACCOUNT=
# SPL token account that receives the protocol fee.
VITE_PROTOCOL_FEE_VAULT=
# (Informational) the SPL mint used for fees in this deployment.
# VITE_TOKEN_MINT=
