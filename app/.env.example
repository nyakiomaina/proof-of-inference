# Solana JSON-RPC (browser). Copy to `.env` and adjust.
# Run `node scripts/devnet-setup.js` to auto-generate values below.

# Optional: explicit endpoint (Helius, Triton, local validator, etc.).
# When set, this wins over VITE_SOLANA_CLUSTER.
# VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# Used when VITE_SOLANA_RPC_URL is unset: devnet | testnet | mainnet-beta
VITE_SOLANA_CLUSTER=devnet

# MXE program id after `arcium deploy` in `mxe/poi_mxe` (for @arcium-hq/client helpers).
# VITE_MXE_PROGRAM_ID=

# SPL token accounts for the verification fee (request_inference).
# These are created by `node scripts/devnet-setup.js`.
VITE_REQUESTER_TOKEN_ACCOUNT=
VITE_PROTOCOL_FEE_VAULT=

# The devnet token mint (for reference, not needed by the frontend).
# VITE_TOKEN_MINT=
